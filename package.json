{
  "name": "career-ops",
  "version": "1.8.0",
  "description": "AI-powered job search pipeline built on Claude Code",
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "verify": "node scripts/verify-pipeline.mjs",
    "normalize": "node scripts/normalize-statuses.mjs",
    "dedup": "node scripts/dedup-tracker.mjs",
    "merge": "node scripts/merge-tracker.mjs",
    "pdf": "node scripts/generate-pdf.mjs",
    "sync-check": "node scripts/cv-sync-check.mjs",
    "update:check": "node scripts/update-system.mjs check",
    "update": "node scripts/update-system.mjs apply",
    "rollback": "node scripts/update-system.mjs rollback",
    "liveness": "node scripts/check-liveness.mjs",
    "scan": "node scripts/scan.mjs",
    "gemini:eval": "node scripts/gemini-eval.mjs",
    "server": "bun packages/server/src/index.mjs",
    "web:dev": "cd packages/web && bunx vite"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation"
  ],
  "author": "Santiago Fernández de Valderrama <hi@santifer.io> (https://santifer.io)",
  "homepage": "https://santifer.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/santifer/career-ops"
  },
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.0.0",
    "js-yaml": "^4.1.1",
    "playwright": "^1.58.1"
  }
}
