# career-ops — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# These are picked up by docker-compose via env_file on the server service.
# LLM keys can also be managed at runtime through the Settings page in the web UI.

# ── Database ──────────────────────────────────────────────────────────────────
# Set automatically by docker-compose. Override only if using an external DB.
# DATABASE_URL=postgresql://career_ops:career_ops_pass@postgres:5432/career_ops

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this in production. Any string works — used to sign JWTs.
JWT_SECRET=change-me-in-production

# Default admin account created on first run (change before deploying)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=changeme

# ── LLM Provider (default, overridable from Settings UI) ─────────────────────
# Supported: deepseek, openai, anthropic, openrouter, gemini
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Optional: other providers (add key if you switch provider in the UI) ──────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# ── Optional: Python agent service URL (default matches docker-compose) ───────
# AGENT_SERVICE_URL=http://agent:8000

OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Search API configuration
# Supported provider: serpapi
SEARCH_API_PROVIDER=serpapi
SEARCH_API_KEY=your_serpapi_api_key_here

# ── Bright Data (for method=brightdata_linkedin) ─────────────────────────────
# BRIGHTDATA_API_KEY=your_brightdata_api_key_here

# ── Other integrations (add your own below) ──────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here   # For Claude-based workflows
# OPENAI_API_KEY=your_openai_key_here          # Future OpenAI integration
